# =========================================================================
# SYSTEM & EDITORS
# =========================================================================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.bak

# =========================================================================
# DEPENDENCIES & PACKAGE MANAGEMENT
# =========================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================================================
# NEXT.JS ARCHITECTURE & PRODUCTION BUILDS
# =========================================================================
/.next/
/out/
/build
/dist
next-env.d.ts
*.tsbuildinfo

# =========================================================================
# EXPERIMENTAL FEATURES & LOCAL ASSETS
# =========================================================================
# Prevents auto-generated audio compilation tracks from muddying git history
/public/audio/
.cache/

# =========================================================================
# SECURITY, PRIVATE TOKENS, & ENVS
# =========================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.vercel
*.pem
gcp-tts-key.json

# =========================================================================
# DEBUGGING & TESTING LOGS
# =========================================================================
/coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================================================================
# SRC / CONTENT EXTRA EXTENSIONS (OPTIONAL DEVELOPER SAFETY NETS)
# =========================================================================
# If you keep rough drafts, notes, or raw copy in your content folders, 
# you can use a ".draft.ts" extension to keep them strictly local:
src/content/**/*.draft.ts
src/content/**/drafts/

# Ignore local component scratchpads or experiment sandboxes if needed:
src/components/**/Experimental*
src/components/**/Sandbox*